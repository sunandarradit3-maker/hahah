rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      // For this app, only the owner (matching email or explicitly set in admins collection)
      return isEmailVerified() && (
        request.auth.token.email == "ditzhaha61@gmail.com" || 
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---

    function isValidProject(data) {
      return data.keys().hasAll(['title', 'slug', 'description', 'category', 'thumbnail']) &&
             data.title is string;
    }

    function isValidPost(data) {
      return data.keys().hasAll(['title', 'slug', 'content', 'thumbnail', 'category']) &&
             data.title is string;
    }

    function isValidLead(data) {
      return data.keys().hasAll(['name', 'message', 'createdAt']);
    }

    // --- Collection Routes ---

    match /projects/{projectId} {
      allow read: if true;
      allow write: if isAdmin() && isValidProject(incoming());
    }

    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /pricing_plans/{planId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /testimonials/{testimonialId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /faqs/{faqId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /blog_posts/{postId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /posts/{postId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /leads/{leadId} {
      allow read: if true; // Enabled for staff PIN login visibility
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable via Firebase Console or special script
    }
  }
}
