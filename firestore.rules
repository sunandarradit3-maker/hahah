rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "ditzhaha61@gmail.com" || 
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // --- Core Collections ---

    match /projects/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /posts/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /leads/{docId} {
      allow read: if true; // Publicly readable for staff visibility
      allow create: if true; // Publicly creatable for contact form
      allow update, delete: if isAdmin();
    }

    // --- Other Collections ---

    match /services/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /testimonials/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // --- Global Safety Net ---
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
